# ---------------------------------------------------------------------------
# Copy this file to .env (used by docker-compose) and adjust values as needed.
# For local (non-Docker) development, export these in your shell or use an
# env manager.
# ---------------------------------------------------------------------------

# --- PostgreSQL (docker-compose "db" service) ---
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
POSTGRES_DB=taskflow

# --- Host port overrides for docker-compose (handy if a port is taken) ---
POSTGRES_PORT=5432
BACKEND_PORT=8090
FRONTEND_PORT=3100

# --- Backend (Go API) ---
# Port the API listens on.
PORT=8090
# Full PostgreSQL connection string (required when running the backend directly).
DATABASE_URL=postgres://taskflow:taskflow@localhost:5432/taskflow?sslmode=disable
# Secret used to sign JWTs. MUST be at least 32 characters. Required.
JWT_SECRET=change-me-to-a-32+-char-secret-in-prod!
# Token lifetime in hours.
JWT_EXPIRY_HOURS=24
# Directory where uploaded attachments are stored.
UPLOAD_DIR=./uploads
# Maximum upload size in bytes (default 10 MiB).
MAX_UPLOAD_BYTES=10485760
# Comma-separated list of allowed CORS origins.
ALLOWED_ORIGINS=http://localhost:3100,http://localhost:3000

# --- Frontend (Next.js) ---
# Base URL of the backend API, baked in at build time.
NEXT_PUBLIC_API_URL=http://localhost:8090
